<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.TingchejiaofeiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.TingchejiaofeiEntity" id="tingchejiaofeiMap">
        <result property="dingdanhao" column="dingdanhao"/>
        <result property="tingchechangmingcheng" column="tingchechangmingcheng"/>
        <result property="quyu" column="quyu"/>
        <result property="xiaoshidanjia" column="xiaoshidanjia"/>
        <result property="yonghuzhanghao" column="yonghuzhanghao"/>
        <result property="xingming" column="xingming"/>
        <result property="shouji" column="shouji"/>
        <result property="chepaihao" column="chepaihao"/>
        <result property="cheliangtupian" column="cheliangtupian"/>
        <result property="jinchangshijian" column="jinchangshijian"/>
        <result property="lichangshijian" column="lichangshijian"/>
        <result property="bencitingcheshizhang" column="bencitingcheshizhang"/>
        <result property="bencitingchefeiyong" column="bencitingchefeiyong"/>
        <result property="crossuserid" column="crossuserid"/>
        <result property="crossrefid" column="crossrefid"/>
        <result property="ispay" column="ispay"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.TingchejiaofeiVO" >
		SELECT * FROM tingchejiaofei  tingchejiaofei         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.TingchejiaofeiVO" >
		SELECT  tingchejiaofei.* FROM tingchejiaofei  tingchejiaofei 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.TingchejiaofeiView" >

		SELECT  tingchejiaofei.* FROM tingchejiaofei  tingchejiaofei 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.TingchejiaofeiView" >
		SELECT * FROM tingchejiaofei  tingchejiaofei <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM tingchejiaofei
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM tingchejiaofei
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM tingchejiaofei
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM tingchejiaofei
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM tingchejiaofei
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>




</mapper>
